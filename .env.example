# Copy this file to .env and fill in your keys

# Anthropic — @claude, @claude-3-5-sonnet, etc.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — @gpt, @gpt-4o, @gpt-4o-mini, etc.
OPENAI_API_KEY=sk-...

# Google Gemini — @gemini, @gemini-1.5-pro, @gemini-2.0-flash, etc.
GEMINI_API_KEY=...

# OpenRouter — @openrouter/meta-llama/llama-3.1-8b-instruct:free, etc.
OPENROUTER_API_KEY=sk-or-...

# Ollama local — @ollama, @ollama:llama3.2, @ollama:mistral, etc.
# Default host (change if Ollama runs elsewhere)
# OLLAMA_HOST=http://localhost:11434
